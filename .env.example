# ═══════════════════════════════════════════════════════════════════
# QAPilot — Environment Variables Reference
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Public frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Public backend API URL (no trailing slash)
BACKEND_URL=http://localhost:5000

# ─── MongoDB ─────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/qapilot
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/qapilot?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/qapilot

# ─── Redis ───────────────────────────────────────────────────────────
# Local: redis://127.0.0.1:6379
# Redis Cloud: redis://:<password>@<host>:<port>
REDIS_URL=redis://127.0.0.1:6379

# ─── Authentication ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace_with_32_char_random_string

# ─── GitHub OAuth ────────────────────────────────────────────────────
# Register at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=http://localhost:5000/api/github/callback

# ─── GitHub Webhooks ─────────────────────────────────────────────────
# Set this in your GitHub repo → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=your_webhook_secret_string

# ─── AI Providers ────────────────────────────────────────────────────
# Set AI_PROVIDER to one of: openai | gemini | claude
AI_PROVIDER=gemini

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Anthropic Claude (https://console.anthropic.com/account/keys)
CLAUDE_API_KEY=sk-ant-...

# ─── Email (optional — for invitation emails) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@qapilot.app

# ─── Frontend Vite Variables ─────────────────────────────────────────
# These are exposed to the React client (prefix with VITE_)
VITE_API_URL=http://localhost:5000
